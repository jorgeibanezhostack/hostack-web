# Supabase — browser-safe (exposed to Vite bundle via VITE_ prefix)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase — server-only (used in /api/* Vercel functions only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Command Center — shared secret for agentic workflow authentication
# External agents send this in the x-api-key header to access task endpoints
COMMAND_CENTER_API_KEY=generate-a-long-random-secret-here

# Email service (existing)
RESEND_API_KEY=your_resend_key_here
